# =============================================================================
# conversational-agents — Environment Configuration
# =============================================================================
# Copy to .env and fill in your values: cp .env.example .env
#
# STRATEGY:
#   Dev local  → .env file + AWS_PROFILE
#   Production → IAM Roles + Secrets Manager + env vars via IaC
# =============================================================================

# --- Environment ---
APP_ENV=dev                          # dev | staging | prod

# --- Domain ---
DOMAIN_DIR=domains/banqi-banking     # Path to active domain directory

# --- AWS Configuration ---
# Dev: use AWS_PROFILE for local credentials
# Prod: leave AWS_PROFILE empty — IAM Role handles auth automatically
AWS_PROFILE=your-aws-profile
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=

# --- Bedrock Model IDs ---
# Model-per-agent: Sonnet for reasoning (Supervisor), Haiku for speed (sub-agents)
# Uses inference profiles (us. prefix) for cross-region failover
SUPERVISOR_AGENT_MODEL_ID=us.anthropic.claude-sonnet-4-6
SERVICES_AGENT_MODEL_ID=us.anthropic.claude-haiku-4-5-20251001-v1:0
KNOWLEDGE_AGENT_MODEL_ID=us.anthropic.claude-haiku-4-5-20251001-v1:0

# --- AgentCore ---
AGENTCORE_MEMORY_ID=
AGENTCORE_AGENT_NAME=                # Required for WhatsApp Lambda — AgentCore Runtime name/ARN
# AGENTCORE_TIMEOUT=30               # Optional — invocation timeout (default: 30s)

# --- AgentCore Feature Flags (reserved for future use) ---
# AGENTCORE_MEMORY_ENABLED=true
# AGENTCORE_OBSERVABILITY_ENABLED=true
# AGENTCORE_GATEWAY_ENABLED=true

# --- Bedrock Knowledge Base ---
BEDROCK_KB_ID=
MIN_SCORE=0.4

# --- Bedrock Guardrails (optional) ---
BEDROCK_GUARDRAIL_ID=
BEDROCK_GUARDRAIL_VERSION=DRAFT

# --- Gateway MCP (optional — set after gateway creation) ---
GATEWAY_MCP_URL=
GATEWAY_CLIENT_ID=
GATEWAY_CLIENT_SECRET=
GATEWAY_TOKEN_ENDPOINT=
GATEWAY_SCOPE=

# --- WhatsApp ---
# Dev: values here / Prod: Secrets Manager (ARN passed as WHATSAPP_SECRET_ARN)
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
# WHATSAPP_API_VERSION=v23.0         # Optional (default: v23.0)
# WHATSAPP_TIMEOUT=10                # Optional (default: 10s)
# DEDUP_TABLE_NAME=                  # Optional — DynamoDB dedup table (set by IaC)
# ERROR_MESSAGE_GENERIC=             # Optional — override error message for WhatsApp

# --- Conversation ---
CONVERSATION_WINDOW_SIZE=10

# --- Observability ---
OPENTELEMETRY_ENABLED=true
