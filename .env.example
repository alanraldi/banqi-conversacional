# =============================================================================
# banQi Conversacional — variáveis de ambiente
# Copiar para .env e preencher os valores para desenvolvimento local.
# NUNCA commitar o arquivo .env!
# =============================================================================

# --- Ambiente ---
APP_ENV=dev
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=123456789012
AWS_PROFILE=banqi-dev        # perfil AWS para credenciais locais

# --- AgentCore ---
AGENTCORE_MEMORY_ID=           # ID do Memory Store (obter após terraform apply)
AGENTCORE_RUNTIME_ARN=         # ARN do AgentCore Runtime
AGENTCORE_GATEWAY_ENDPOINT=    # URL do AgentCore Gateway MCP

# --- Gateway OAuth (Cognito) ---
GATEWAY_CLIENT_ID=
GATEWAY_CLIENT_SECRET=
GATEWAY_TOKEN_ENDPOINT=
GATEWAY_SCOPE=

# --- Bedrock Guardrails ---
BEDROCK_GUARDRAIL_ID=
BEDROCK_GUARDRAIL_VERSION=DRAFT

# --- Modelos Claude ---
SUPERVISOR_AGENT_MODEL_ID=us.anthropic.claude-sonnet-4-6-20250514-v1:0
CONSIGNADO_AGENT_MODEL_ID=us.anthropic.claude-haiku-4-5-20251001-v1:0
GENERAL_AGENT_MODEL_ID=us.anthropic.claude-haiku-4-5-20251001-v1:0

# --- WhatsApp Business API ---
WHATSAPP_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# --- DynamoDB ---
DEDUP_TABLE_NAME=              # Tabela de deduplicação de mensagens
SESSION_TABLE_NAME=            # Tabela de sessões ativas (correlação webhooks)

# --- API banQi ---
BANQI_API_BASE_URL=https://api.banqi.com.br   # sandbox: https://sandbox-api.banqi.com.br

# --- Desenvolvimento (mock local) ---
# Para usar o mock local em vez da API real:
# BANQI_API_BASE_URL=http://localhost:8000

# --- Domínio ---
DOMAIN_SLUG=banqi-consignado
