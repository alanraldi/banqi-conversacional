# =============================================================================
# banQi Conversacional — variáveis de ambiente
# Copiar para .env e preencher os valores.
# NUNCA commitar o arquivo .env!
# =============================================================================

# --- Ambiente ---
APP_ENV=dev                          # dev | staging | prod
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=123456789012          # sua conta AWS (12 dígitos)
AWS_PROFILE=banqi-dev                # perfil AWS local (apenas dev)

# --- AgentCore (preencher após terraform apply) ---
AGENTCORE_MEMORY_ID=                 # ex: mem-xxxxxxxxxxxxxxxx
AGENTCORE_RUNTIME_ARN=               # ex: arn:aws:bedrock-agentcore:us-east-1:123456789012:agent-runtime/...
AGENTCORE_GATEWAY_ENDPOINT=          # ex: https://gateway.bedrock-agentcore.us-east-1.amazonaws.com/mcp/...

# --- Gateway OAuth (Cognito — preencher após terraform apply) ---
GATEWAY_CLIENT_ID=
GATEWAY_CLIENT_SECRET=
GATEWAY_TOKEN_ENDPOINT=             # ex: https://<pool>.auth.us-east-1.amazoncognito.com/oauth2/token
GATEWAY_SCOPE=                      # ex: banqi-consignado-staging-gateway/invoke

# --- Bedrock Guardrails (preencher após terraform apply) ---
BEDROCK_GUARDRAIL_ID=               # ex: gr-xxxxxxxxxxxxxxxx
BEDROCK_GUARDRAIL_VERSION=DRAFT     # DRAFT em dev, número da versão em prod

# --- Modelos Claude (IDs cross-region para us-east-1) ---
SUPERVISOR_AGENT_MODEL_ID=us.anthropic.claude-sonnet-4-6-20250514-v1:0
CONSIGNADO_AGENT_MODEL_ID=us.anthropic.claude-haiku-4-5-20251001-v1:0
GENERAL_AGENT_MODEL_ID=us.anthropic.claude-haiku-4-5-20251001-v1:0

# --- WhatsApp Business API (Meta Developer Portal) ---
WHATSAPP_TOKEN=                      # token de acesso permanente do Meta
WHATSAPP_APP_SECRET=                 # app secret para validar webhooks
WHATSAPP_VERIFY_TOKEN=               # token de verificação do webhook (você escolhe)
WHATSAPP_PHONE_NUMBER_ID=            # ID do número de telefone no Meta (numérico)

# --- DynamoDB (preencher após terraform apply) ---
DEDUP_TABLE_NAME=banqi-consignado-staging-dedup   # tabela de deduplicação
SESSION_TABLE_NAME=banqi-consignado-staging-sessions # tabela de sessões

# --- API banQi ---
BANQI_API_BASE_URL=https://api.banqi.com.br        # prod
# BANQI_API_BASE_URL=https://sandbox-api.banqi.com.br  # sandbox (quando disponível)

# --- Domínio ---
DOMAIN_SLUG=banqi-consignado
